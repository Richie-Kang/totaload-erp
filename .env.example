# Totaload ERP — environment variables (copy to .env for local dev)

# PostgreSQL connection string used by the backend.
DATABASE_URL=postgresql://totaload:totaload@localhost:5432/totaload

# Node backend HTTP port.
BACKEND_PORT=4000

# URL the backend uses to reach the Python OCR/PDF service.
OCR_SERVICE_URL=http://localhost:8000

# Python OCR/PDF service HTTP port.
OCR_PORT=8000

# Allowed browser origin for CORS (the frontend dev server / deployed site).
CORS_ORIGIN=http://localhost:5173

# Path to the malso application AcroForm PDF template.
TEMPLATE_PATH=./assets/malso_application_template.pdf

# Codex auth: leave EMPTY for local dev (the ocr-service uses the host's ~/.codex).
# For deployment, paste the contents of ~/.codex/auth.json here so the container can
# write it to ~/.codex/auth.json on startup.
CODEX_AUTH_JSON=
